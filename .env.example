# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production-use-50-random-characters
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.everestcakes.co.ke

# Database (PostgreSQL recommended for production)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://everest:password@localhost:5432/everest_cakes

# Redis (for Celery and caching)
REDIS_URL=redis://localhost:6379/0

# Site Configuration
SITE_URL=http://localhost:8000
SITE_NAME=Everest Cakes

# Email Settings (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Everest Cakes <info@everestcakes.com>

# Admin Email (receives order/enquiry notifications)
ADMIN_EMAIL=admin@everestcakes.co.ke

# M-Pesa Configuration (Safaricom Daraja API)
# Get credentials from: https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
# For production (Lipa Na M-Pesa):
# MPESA_SHORTCODE=your-till-or-paybill-number
# MPESA_ENVIRONMENT=production

# WhatsApp Business API
# Get credentials from: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
ADMIN_WHATSAPP_NUMBER=254712345678

# Business Information
BUSINESS_NAME=Everest Cakes
BUSINESS_PHONE=+254700000000
BUSINESS_WHATSAPP=+254700000000
BUSINESS_EMAIL=info@everestcakes.com
BUSINESS_ADDRESS=Thika, Kenya

# Business Hours
MONDAY_FRIDAY=8:00 AM - 7:00 PM
SATURDAY=8:00 AM - 7:00 PM
SUNDAY=10:00 AM - 4:00 PM

# Delivery Settings
FREE_DELIVERY_THRESHOLD=5000
DEFAULT_DELIVERY_FEE=300

# Social Media URLs
FACEBOOK_URL=https://facebook.com/everestcakes
INSTAGRAM_URL=https://instagram.com/everestcakes
TWITTER_URL=https://twitter.com/everestcakes
TIKTOK_URL=

# Google Analytics (optional)
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Allowed file upload size (in MB)
MAX_UPLOAD_SIZE=10

# JWT/Session Settings
SESSION_COOKIE_AGE=1209600
